# MongoDB Configuration
MONGODB_URI=mongodb+srv://admin:door1door2@cluster0.akyfbgq.mongodb.net/movieportal
# I've added my deployed mongoDB URI here, but you should replace it with your own URI.

# JWT Configuration
JWT_SECRET=jwtsecretkey

# Backend Configuration
BACKEND_PORT=5000
NODE_ENV=development

# CORS Configuration - Allowed origins (comma-separated)
# Format: http://localhost:3000,http://localhost:80,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost,http://localhost:5173

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Auth Cookie Configuration (optional)
# Use secure=true and sameSite=none for HTTPS cross-site deployments.
AUTH_COOKIE_NAME=auth_token
AUTH_COOKIE_MAX_AGE_MS=604800000
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
