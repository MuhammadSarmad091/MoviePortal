{
  "name": "movie-web-app-backend",
  "version": "1.0.0",
  "description": "Backend API for Movie Web App",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "cross-env NODE_ENV=test jest --detectOpenHandles --forceExit",
    "test:unit": "cross-env NODE_ENV=test jest --testPathPattern=\"src/.*\\.test\\.js$\" --passWithNoTests",
    "test:integration": "cross-env NODE_ENV=test jest --testPathPattern=\"tests/integration/.*\\.test\\.js$\" --detectOpenHandles --forceExit",
    "test:integration:watch": "cross-env NODE_ENV=test jest --testPathPattern=\"tests/integration/.*\\.test\\.js$\" --watch --detectOpenHandles",
    "test:all": "cross-env NODE_ENV=test jest --detectOpenHandles --forceExit",
    "seed": "node scripts/seed.js",
    "migrate:indexes": "node scripts/migrations/001-create-movie-review-indexes.js"
  },
  "keywords": [
    "movie",
    "api",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
