# Test Environment Configuration
NODE_ENV=test

# Test Database
MONGODB_URI=mongodb://testuser:testpass@localhost:27017/test_db?authSource=admin

# JWT Configuration
JWT_SECRET=test-jwt-secret-key-for-testing-only-not-for-production
JWT_EXPIRY=7d

# CORS Settings (allow all for tests)
CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost,http://localhost:5173

# API Configuration
API_PORT=4000
LOG_LEVEL=error

# Feature Flags
ENABLE_SEEDING=true
